const TT={backgroundColor:'#0d1728',borderColor:'rgba(80,140,220,0.3)',borderWidth:1,titleColor:'#e8f2ff',bodyColor:'#8aabcc',footerColor:'#c0d8f0',padding:14,titleFont:{size:12,weight:'bold'},bodyFont:{size:11},footerFont:{size:11},itemSpacing:4};

function ttFooter(items){
  const i = items[0].dataIndex;
  return ['──────────────────',
