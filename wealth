<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=IBM+Plex+Mono:wght@400;600&display=swap');
:root{--bg:#06080f;--s1:#0b1019;--s2:#0f1520;--border:rgba(80,140,220,0.1);--A:#00d68f;--B:#4d9eff;--C:#ff6b35;--text:#ccdaec;--muted:#4a6080;--gold:#f5c030;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans TC',sans-serif;padding:22px 14px 60px;background-image:radial-gradient(ellipse 55% 30% at 8% 0%,rgba(0,214,143,.04) 0%,transparent 55%),radial-gradient(ellipse 45% 25% at 92% 100%,rgba(77,158,255,.04) 0%,transparent 55%);}
.wrap{max-width:960px;margin:0 auto;}
.top-hdr{text-align:center;margin-bottom:20px;}
.eyebrow{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
h1{font-size:clamp(20px,4vw,32px);font-weight:900;letter-spacing:-1px;line-height:1.2;}
.gold{color:var(--gold);}
.top-sub{font-size:11px;color:var(--muted);font-family:'IBM Plex Mono',monospace;margin-top:6px;line-height:1.8;}
.live-strip{display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap;margin-top:10px;font-family:'IBM Plex Mono',monospace;font-size:11px;background:rgba(0,214,143,.06);border:1px solid rgba(0,214,143,.2);border-radius:8px;padding:8px 16px;}
.dot{width:7px;height:7px;border-radius:50%;background:var(--A);animation:pulse 1.5s infinite;flex-shrink:0;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.li b{color:var(--A);} .li span{color:var(--muted);margin-right:3px;} .sep{color:var(--muted);}
.info-box{border-radius:8px;padding:10px 14px;font-size:11px;font-family:'IBM Plex Mono',monospace;line-height:1.9;margin-bottom:12px;}
.info-box.green{background:rgba(0,214,143,.06);border:1px solid rgba(0,214,143,.2);color:#60c8a0;}
.info-box.blue{background:rgba(77,158,255,.06);border:1px solid rgba(77,158,255,.2);color:#7ab4f0;}
.tabs-wrap{margin:18px 0;}
.tabs-hint{text-align:center;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--gold);margin-bottom:10px;animation:hintPulse 2s ease-in-out infinite;}
@keyframes hintPulse{0%,100%{opacity:.6}50%{opacity:1}}
.tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:6px;position:relative;}
.tabs::before{content:'';position:absolute;top:-1px;left:-1px;right:-1px;bottom:-1px;border-radius:12px;background:linear-gradient(90deg,var(--A),var(--B),var(--C),var(--gold));opacity:0.3;z-index:-1;filter:blur(8px);}
.tab{font-family:'Noto Sans TC',sans-serif;font-size:13px;font-weight:700;padding:14px 8px;border-radius:8px;cursor:pointer;background:transparent;color:var(--muted);transition:all .25s;text-align:center;border:1px solid transparent;position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;gap:4px;line-height:1.2;}
.tab-icon{font-size:20px;line-height:1;}
.tab-text{font-size:11px;letter-spacing:0.5px;}
.tab:hover:not(.active){background:rgba(255,255,255,.04);color:var(--text);transform:translateY(-1px);}
.tab.active{background:linear-gradient(180deg,rgba(0,214,143,.18),rgba(0,214,143,.08));color:var(--A);border-color:rgba(0,214,143,.5);box-shadow:0 4px 12px rgba(0,214,143,.15),inset 0 1px 0 rgba(0,214,143,.2);}
.tab.active .tab-icon{filter:drop-shadow(0 0 8px rgba(0,214,143,.6));}
.tab-num{position:absolute;top:4px;right:6px;font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);font-weight:400;opacity:0.6;}
.tab.active .tab-num{color:var(--A);opacity:1;}
@media(max-width:540px){
  .tab-text{font-size:10px;}
  .tab-icon{font-size:18px;}
  .tab{padding:10px 4px;}
}
.legend{display:flex;justify-content:center;gap:18px;margin-bottom:12px;flex-wrap:wrap;}
.leg{display:flex;align-items:center;gap:6px;font-size:12px;}
.leg-line{width:24px;height:2.5px;border-radius:2px;}
.leg-sub{font-size:9px;color:var(--muted);font-family:'IBM Plex Mono',monospace;}
.chart-box{background:var(--s1);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:14px;}
.chart-box::before{content:'';display:block;height:3px;background:linear-gradient(90deg,var(--A),var(--B),var(--C));}
.chart-inner{padding:16px 12px 12px;}
.chart-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);text-align:center;margin-bottom:10px;}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.card{background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:13px 10px;text-align:center;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.cA::before{background:var(--A);}.cB::before{background:var(--B);}.cC::before{background:var(--C);}
.card-lbl{font-size:9px;font-family:'IBM Plex Mono',monospace;color:var(--muted);margin-bottom:5px;letter-spacing:1px;text-transform:uppercase;}
.card-val{font-size:clamp(13px,2.8vw,20px);font-weight:900;font-family:'IBM Plex Mono',monospace;line-height:1.1;}
.tA{color:var(--A);}.tB{color:var(--B);}.tC{color:var(--C);}
.card-sub{font-size:9px;color:var(--muted);margin-top:3px;}
.badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;margin-top:5px;font-family:'IBM Plex Mono',monospace;}
.bA{background:rgba(0,214,143,.1);color:var(--A);}
.bB{background:rgba(77,158,255,.1);color:var(--B);}
.bC{background:rgba(255,107,53,.1);color:var(--C);}
.info-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px;}
.info-card{background:var(--s2);border:1px solid var(--border);border-radius:9px;padding:10px;text-align:center;}
.info-lbl{font-size:9px;color:var(--muted);font-family:'IBM Plex Mono',monospace;margin-bottom:4px;letter-spacing:1px;text-transform:uppercase;}
.info-val{font-size:clamp(12px,2.4vw,16px);font-weight:900;font-family:'IBM Plex Mono',monospace;}
.panel{display:none;}.panel.active{display:block;}
.sec-div{display:flex;align-items:center;gap:12px;margin:14px 0 10px;}
.sec-div::before,.sec-div::after{content:'';flex:1;height:1px;background:var(--border);}
.sec-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);white-space:nowrap;}
.note{background:var(--s2);border:1px solid var(--border);border-radius:9px;padding:10px 14px;font-size:10px;color:var(--muted);font-family:'IBM Plex Mono',monospace;line-height:1.9;margin-top:8px;}
.note strong{color:#6a8090;}
@media(max-width:540px){.cards{grid-template-columns:1fr;}.info-row{grid-template-columns:1fr 1fr;}.legend{gap:10px;}}
</style>
</head>
