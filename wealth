function xSc(){return{grid:{color:'rgba(80,140,220,0.04)'},ticks:{font:{size:10},maxRotation:0,autoSkip:false,callback:(v,i)=>xLbls[i]||null},border:{color:'rgba(80,140,220,0.1)'}};}

function mkDs(label,data,color){return{label,data,borderColor:color,backgroundColor:'transparent',borderWidth:2,pointRadius:0,pointHoverRadius:5,pointHoverBackgroundColor:color,pointHoverBorderColor:'#06080f',pointHoverBorderWidth:2,tension:0,fill:false};}
function mkDash(label,data,color){return{label,data,borderColor:color,backgroundColor:'transparent',borderWidth:1.5,borderDash:[5,4],pointRadius:0,tension:0,fill:false};}

