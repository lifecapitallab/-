 ['2',D.wT_A,D.wT_B,D.wT_C,D.total_invest[L],false]
].forEach(([p,A,B,C,cost,isLump]) => {
  const fA=A[L], fB=B[L], fC=C[L];
  document.getElementById(`v${p}A`).textContent = fmt(fA);
  document.getElementById(`v${p}B`).textContent = fmt(fB);
  document.getElementById(`v${p}C`).textContent = fmt(fC);
  if(isLump){
    document.getElementById(`m${p}A`).textContent = '×'+(fA/LUMP).toFixed(1);
    document.getElementById(`m${p}B`).textContent = '×'+(fB/LUMP).toFixed(1);
    document.getElementById(`m${p}C`).textContent = '×'+(fC/LUMP).toFixed(1);
  } else {
    ['A','B','C'].forEach((k,j) => {
      const v=[fA,fB,fC][j];
      document.getElementById(`r${p}${k}`).textContent = '+'+Math.round((v-cost)/cost*100)+'%';
    });
  }
});

