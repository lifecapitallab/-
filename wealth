function fmt(n){if(n>=1e8)return(n/1e8).toFixed(2)+'億';if(n>=1e4)return Math.round(n/1e4)+'萬';return Math.round(n).toLocaleString();}
function fmtDate(s){return s.replace(/-/g,'/');}

